$ErrorActionPreference = "Stop"

$isWindowsHost = if (Get-Variable IsWindows -ErrorAction SilentlyContinue) { $IsWindows } else { $env:OS -eq "Windows_NT" }
if (-not $isWindowsHost) {
  Write-Host "Skipping Windows font install on non-Windows host."
  exit 0
}

$sourceRoot = '{{ .chezmoi.sourceDir }}'
$scriptPath = Join-Path $sourceRoot 'scripts\install\fonts-windows.ps1'
$fontSource = Join-Path $sourceRoot '0xProto'

& $scriptPath -SourceDir $fontSource
{{- end -}}
