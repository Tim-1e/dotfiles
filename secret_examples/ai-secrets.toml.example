# Copy to ~/.ai-secrets/secrets.toml and fill only the profiles you use.
# This file is intentionally not managed by chezmoi.

[codex.api]
OPENAI_API_KEY = "sk-your-default-codex-api-key"

[claude.api]
ANTHROPIC_BASE_URL = "https://anyrouter.top"
ANTHROPIC_API_KEY = "sk-ant-your-claude-api-key"
# Or use ANTHROPIC_AUTH_TOKEN if your router expects Bearer auth:
# ANTHROPIC_AUTH_TOKEN = "your-router-token"

[claude.api-docker]
ANTHROPIC_BASE_URL = "https://anyrouter.top"
ANTHROPIC_AUTH_TOKEN = "your-docker-router-token"
