    { "type": "command", "key": "{$6}\u001b[38;5;213m  у°ғӯ OS Age   \u001b[0m", "text": "if [ -f /etc/machine-id ]; then born=$(stat -c %Y /etc/machine-id 2>/dev/null); now=$(date +%s); days=$(( (now-born)/86400 )); printf '%s (%d days)\\n' \"$(date -d @$born '+%Y-%m-%d' 2>/dev/null)\" \"$days\"; fi" },
