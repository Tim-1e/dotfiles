    { "type": "command", "key": "{$5}\u001b[38;5;229m  уұҳ— Rust     \u001b[0m", "text": "command -v rustc >/dev/null 2>&1 && rustc --version 2>/dev/null | awk '{print $2}'" },
    { "type": "command", "key": "{$5}\u001b[38;5;229m  у°ҷІ Clang    \u001b[0m", "text": "command -v clang >/dev/null 2>&1 && clang --version 2>/dev/null | head -1 | awk '{print $3}'" },
    { "type": "command", "key": "{$5}\u001b[38;5;229m  у°Ҹ— Node.js  \u001b[0m", "text": "command -v node >/dev/null 2>&1 && node -v 2>/dev/null | sed 's/^v//'" },
    { "type": "command", "key": "{$5}\u001b[38;5;229m  у°ҹ“ Go       \u001b[0m", "text": "command -v go >/dev/null 2>&1 && go version 2>/dev/null | awk '{print $3}' | sed 's/^go//'" },
