fi

alias gs="git status"
alias py="python3"
alias cls="clear"
alias deact="deactivate"

if command -v eza >/dev/null 2>&1; then
  alias ls='eza --icons'
  alias ll='eza -la --icons --git'
  alias la='eza -a --icons'
  alias lt='eza --tree --level=2 --icons'
  alias llt='eza --tree --level=3 --icons --git'
fi

if command -v bat >/dev/null 2>&1; then
  alias cat='bat'
elif command -v batcat >/dev/null 2>&1; then
  alias cat='batcat'
fi

# Modern CLI replacements (installed user-level into ~/.local/bin by
# scripts/install/modern-cli.sh). Only clobber a builtin when the replacement
# is a safe interactive drop-in; rg/fd/sd/jq/yq/xh/delta stay as their own
# commands (NOT aliased over grep/find/sed) because their flags differ and
# aliasing them would break scripts and muscle memory.
command -v dust  >/dev/null 2>&1 && alias du='dust'
command -v duf   >/dev/null 2>&1 && alias df='duf'
command -v procs >/dev/null 2>&1 && alias ps='procs'
command -v gping >/dev/null 2>&1 && alias ping='gping'
if command -v btop >/dev/null 2>&1; then
  alias top='btop'
  alias htop='btop'
fi

# Use fd for fzf's file/dir walks when available (faster, respects .gitignore).
if command -v fd >/dev/null 2>&1; then
  export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
  export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'
fi

source /usr/share/doc/fzf/examples/key-bindings.zsh 2>/dev/null || true
source /usr/share/doc/fzf/examples/completion.zsh 2>/dev/null || true

export FZF_DEFAULT_OPTS='--height=40% --layout=reverse --border'
export FZF_CTRL_T_OPTS="--preview 'batcat --color=always {} 2>/dev/null || bat --color=always {} 2>/dev/null || command cat {}'"
export FZF_ALT_C_OPTS="--preview 'eza --tree --level=2 --icons {} 2>/dev/null || ls -la {}'"

if [ -f "$HOME/.claude/auth.env" ]; then
  set -a
  . "$HOME/.claude/auth.env"
  set +a
fi

# cxcc profile wrappers managed by the pinned release installer.
_cxcc_home="${CXCC_HOME:-$HOME/.local/share/cxcc}"
if [ -f "$_cxcc_home/load.sh" ]; then
  source "$_cxcc_home/load.sh"
fi
unset _cxcc_home

zd() {
  local dir
  dir=$(zoxide query -l 2>/dev/null | fzf --preview 'eza --tree --level=2 --icons {} 2>/dev/null || ls -la {}')
  [ -n "$dir" ] && cd "$dir"
}

act() {
  if [ -z "${1:-}" ]; then
    if [ -f ".venv/bin/activate" ]; then
      source .venv/bin/activate
    else
      echo "No .venv in current directory"
    fi
  else
    source "$HOME/pyenvs/$1/bin/activate"
  fi
}

# Run Claude with permissions auto-skipped (convenience wrapper).
alias claude='claude --dangerously-skip-permissions'

# No proxy Set
alias codex-np='env -u HTTP_PROXY -u HTTPS_PROXY -u ALL_PROXY -u NO_PROXY -u http_proxy -u https_proxy -u all_proxy -u no_proxy codex'
alias claude-np='env -u HTTP_PROXY -u HTTPS_PROXY -u ALL_PROXY -u NO_PROXY -u http_proxy -u https_proxy -u all_proxy -u no_proxy claude'

echo "zsh已经重新加载" | lolcrab
