# Zsh environment managed by chezmoi.

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="amuse"
plugins=(git zsh-autosuggestions zsh-syntax-highlighting virtualenv)

export PATH="$HOME/.local/bin:$HOME/.cargo/bin:/usr/local/cargo/bin:$PATH"
export VISUAL=nano
export EDITOR=nano

# Locale / terminal — avoids locale warnings in minimal Linux/docker shells.
export LANG=C.UTF-8
export LC_CTYPE=C.UTF-8
export TERM="${TERM:-xterm-256color}"
unset LC_ALL

if [ -f "$ZSH/oh-my-zsh.sh" ]; then
  source "$ZSH/oh-my-zsh.sh"
fi

if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
  alias cd='z'
fi

if command -v fastfetch >/dev/null 2>&1 && fastfetch --version >/dev/null 2>&1; then
  fastfetch
fi

if command -v lolcrab >/dev/null 2>&1; then
  cat << 'EOF' | lolcrab -g turbo
